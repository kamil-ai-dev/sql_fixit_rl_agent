# SQL Debug Environment - Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# LLM API endpoint
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier for inference
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Your Hugging Face / API key
HF_TOKEN=your_hf_token_here

# Docker image name (set after building)
LOCAL_IMAGE_NAME=sql-debug-env:latest

# Use Docker for environment (true) or HTTP to a running server (false)
USE_DOCKER=true
